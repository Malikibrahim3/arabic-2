    "path": "/audio/dialects/egyptian/quran/quran_114_3.mp3"
  },
  "quran_103_1": {
    "text": "وَالعَصر",
    "path": "/audio/dialects/egyptian/quran/quran_103_1.mp3"
  },
  "quran_103_2": {
    "text": "إِنَّ الإِنسانَ لَفي خُسر",
