  },
  "sent_jazak_allah": {
    "text": "جَزاكَ اللّه خَيرًا",
    "path": "/audio/dialects/egyptian/sentences/sent_jazak_allah.mp3"
  },
  "conv1_line1": {
    "text": "اَلسَّلامُ عَلَيكُم",
    "path": "/audio/dialects/egyptian/conversations/conv1_line1.mp3"
  },
  "conv1_line2": {
    "text": "وَعَلَيكُمُ السَّلامُ",
    "path": "/audio/dialects/egyptian/conversations/conv1_line2.mp3"
  },
  "conv1_line3": {
    "text": "كَيفَ حالُكِ؟",
    "path": "/audio/dialects/egyptian/conversations/conv1_line3.mp3"
  },
  "conv1_line4": {
    "text": "أَنا بِخَير، شُكرًا",
    "path": "/audio/dialects/egyptian/conversations/conv1_line4.mp3"
  },
  "conv1_line5": {
    "text": "أَنا بِخَير أَيضًا",
    "path": "/audio/dialects/egyptian/conversations/conv1_line5.mp3"
  },
  "conv1_line6": {
    "text": "مَعَ السَّلامة",
    "path": "/audio/dialects/egyptian/conversations/conv1_line6.mp3"
  },
  "conv2_line1": {
    "text": "صَباحُ الخَير",
    "path": "/audio/dialects/egyptian/conversations/conv2_line1.mp3"
  },
  "conv2_line2": {
    "text": "صَباحُ النُّور",
    "path": "/audio/dialects/egyptian/conversations/conv2_line2.mp3"
  },
  "conv2_line3": {
    "text": "هَذِهِ مَدرَسة",
    "path": "/audio/dialects/egyptian/conversations/conv2_line3.mp3"
  },
  "conv2_line4": {
    "text": "نَعَم، هَذِهِ مَدرَسة جَميلة",
    "path": "/audio/dialects/egyptian/conversations/conv2_line4.mp3"
  },
  "conv2_line5": {
    "text": "أَنا أُحِبُّ العَرَبيّة",
    "path": "/audio/dialects/egyptian/conversations/conv2_line5.mp3"
  },
  "conv2_line6": {
    "text": "أَنا أُحِبُّ العَرَبيّة أَيضًا",
    "path": "/audio/dialects/egyptian/conversations/conv2_line6.mp3"
  },
  "conv3_line1": {
    "text": "هَذا كِتاب",
    "path": "/audio/dialects/egyptian/conversations/conv3_line1.mp3"
  },
  "conv3_line2": {
    "text": "كِتابٌ جَميل",
    "path": "/audio/dialects/egyptian/conversations/conv3_line2.mp3"
  },
  "conv3_line3": {
    "text": "شُكرًا",
    "path": "/audio/dialects/egyptian/conversations/conv3_line3.mp3"
  },
  "conv3_line4": {
    "text": "عَفوًا",
    "path": "/audio/dialects/egyptian/conversations/conv3_line4.mp3"
  },
  "conv3_line5": {
    "text": "مَعَ السَّلامة",
    "path": "/audio/dialects/egyptian/conversations/conv3_line5.mp3"
  },
  "conv3_line6": {
    "text": "مَعَ السَّلامة",
    "path": "/audio/dialects/egyptian/conversations/conv3_line6.mp3"
  },
  "conv4_line1": {
    "text": "بِسمِ اللّه",
    "path": "/audio/dialects/egyptian/conversations/conv4_line1.mp3"
  },
  "conv4_line2": {
    "text": "بِسمِ اللّه",
    "path": "/audio/dialects/egyptian/conversations/conv4_line2.mp3"
  },
  "conv4_line3": {
    "text": "اَلسَّلامُ عَلَيكُم",
    "path": "/audio/dialects/egyptian/conversations/conv4_line3.mp3"
  },
  "conv4_line4": {
    "text": "وَعَلَيكُمُ السَّلامُ",
    "path": "/audio/dialects/egyptian/conversations/conv4_line4.mp3"
  },
  "conv4_line5": {
    "text": "كَيفَ حالُكُم؟",
    "path": "/audio/dialects/egyptian/conversations/conv4_line5.mp3"
  },
  "conv4_line6": {
    "text": "نَحنُ بِخَير",
    "path": "/audio/dialects/egyptian/conversations/conv4_line6.mp3"
  },
  "conv5_line1": {
    "text": "اَلسَّلامُ عَلَيكُم",
    "path": "/audio/dialects/egyptian/conversations/conv5_line1.mp3"
  },
  "conv5_line2": {
    "text": "وَعَلَيكُمُ السَّلامُ",
    "path": "/audio/dialects/egyptian/conversations/conv5_line2.mp3"
  },
  "conv5_line3": {
    "text": "اسمك إيه؟",
    "path": "/audio/dialects/egyptian/conversations/conv5_line3.mp3"
  },
  "conv5_line4": {
    "text": "اِسمي أَحمَد",
    "path": "/audio/dialects/egyptian/conversations/conv5_line4.mp3"
  },
  "conv5_line5": {
    "text": "اِسمي فاطِمة",
    "path": "/audio/dialects/egyptian/conversations/conv5_line5.mp3"
  },
  "conv5_line6": {
    "text": "تَشَرَّفنا",
    "path": "/audio/dialects/egyptian/conversations/conv5_line6.mp3"
  },
  "conv6_line1": {
    "text": "مَساءُ الخَير",
    "path": "/audio/dialects/egyptian/conversations/conv6_line1.mp3"
  },
  "conv6_line2": {
    "text": "مَساءُ النُّور",
    "path": "/audio/dialects/egyptian/conversations/conv6_line2.mp3"
  },
  "conv6_line3": {
    "text": "كَيفَ حالُكَ؟",
    "path": "/audio/dialects/egyptian/conversations/conv6_line3.mp3"
  },
  "conv6_line4": {
    "text": "أَنا بِخَير، الحَمدُ لِلّه",
    "path": "/audio/dialects/egyptian/conversations/conv6_line4.mp3"
  },
  "conv6_line5": {
    "text": "جَيِّد",
    "path": "/audio/dialects/egyptian/conversations/conv6_line5.mp3"
  },
  "conv6_line6": {
    "text": "مَعَ السَّلامة",
    "path": "/audio/dialects/egyptian/conversations/conv6_line6.mp3"
  },
  "conv8_1_line1": {
    "text": "أَهلًا وَسَهلًا بِكَ في مَطعَمِنا",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line1.mp3"
  },
  "conv8_1_line2": {
    "text": "شُكرًا، هَذا المَكانُ جَميلٌ جِدًّا",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line2.mp3"
  },
  "conv8_1_line3": {
    "text": "نَحنُ سُعَداءُ بِزِيارَتِكَ، ما الَّذي تُفَضِّلُهُ اليَومَ؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line3.mp3"
  },
  "conv8_1_line4": {
    "text": "ما هُوَ أَشهَرُ طَبَقٍ عِندَكُم؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line4.mp3"
  },
  "conv8_1_line5": {
    "text": "الكَبسَةُ بِاللَّحمِ هِيَ الأَشهَرُ وَالأَلَذّ",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line5.mp3"
  },
  "conv8_1_line6": {
    "text": "مُمتازٌ، سَآخُذُ الكَبسَةَ مَعَ سَلَطَةٍ وَعَصيرِ بُرتُقال",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line6.mp3"
  },
  "conv8_1_line7": {
    "text": "اختِيارٌ رائِعٌ، هَل تُريدُ الطَّبَقَ حارًّا أَم مُتَوَسِّطًا؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line7.mp3"
  },
  "conv8_1_line8": {
    "text": "مُتَوَسِّطًا مِن فَضلِكَ، وَكَم يَستَغرِقُ التَّحضير؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line8.mp3"
  },
  "conv8_1_line9": {
    "text": "حَوالَي عِشرينَ دَقيقَةً، هَل تُريدُ مُقَبِّلاتٍ أَثناءَ الانتِظار؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line9.mp3"
  },
  "conv8_1_line10": {
    "text": "نَعَم، أَحضِر لي حُمُّصًا وَخُبزًا طازَجًا",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line10.mp3"
  },
  "conv8_1_line11": {
    "text": "حاضِرٌ، سَأُحضِرُها فَورًا، بِالهَناءِ وَالشِّفاء",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line11.mp3"
  },
  "conv8_1_line12": {
    "text": "شُكرًا جَزيلًا، اللهُ يُبارِكُ فيكَ",
    "path": "/audio/dialects/egyptian/conversations/conv8_1_line12.mp3"
  },
  "conv8_2_line1": {
    "text": "صَباحُ الخَيرِ، تَفَضَّل بِالجُلوس",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line1.mp3"
  },
  "conv8_2_line2": {
    "text": "صَباحُ النُّورِ، شُكرًا لِإِتاحَةِ هَذِهِ الفُرصَة",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line2.mp3"
  },
  "conv8_2_line3": {
    "text": "أَخبِرني عَن خِبرَتِكَ العَمَليَّةِ السّابِقَة",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line3.mp3"
  },
  "conv8_2_line4": {
    "text": "عَمِلتُ خَمسَ سَنَواتٍ في شَرِكَةٍ كَبيرَةٍ كَمُهَندِس",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line4.mp3"
  },
  "conv8_2_line5": {
    "text": "مُمتازٌ، وَما هِيَ أَهَمُّ إِنجازاتِكَ هُناكَ؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line5.mp3"
  },
  "conv8_2_line6": {
    "text": "قُدتُ فَريقًا نَجَحَ في تَطويرِ نِظامٍ جَديد",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line6.mp3"
  },
  "conv8_2_line7": {
    "text": "رائِعٌ، لِماذا تُريدُ العَمَلَ مَعَنا بِالتَّحديد؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line7.mp3"
  },
  "conv8_2_line8": {
    "text": "لِأَنَّ شَرِكَتَكُم رائِدَةٌ في المَجالِ وَلَدَيها سُمعَةٌ مُمتازَة",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line8.mp3"
  },
  "conv8_2_line9": {
    "text": "ما هِيَ نِقاطُ قُوَّتِكَ وَضَعفِك؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line9.mp3"
  },
  "conv8_2_line10": {
    "text": "أَنا مُجتَهِدٌ وَمُنَظَّمٌ، لَكِنّي أَحيانًا أَكونُ مُتَطَلِّبًا جِدًّا",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line10.mp3"
  },
  "conv8_2_line11": {
    "text": "جَيِّدٌ، سَنَتَّصِلُ بِكَ خِلالَ أُسبوعٍ بِإِذنِ الله",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line11.mp3"
  },
  "conv8_2_line12": {
    "text": "شُكرًا جَزيلًا، في انتِظارِ رَدِّكُم",
    "path": "/audio/dialects/egyptian/conversations/conv8_2_line12.mp3"
  },
  "conv8_3_line1": {
    "text": "أُفَكِّرُ في السَّفَرِ إِلى تُركِيا الشَّهرَ القادِم",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line1.mp3"
  },
  "conv8_3_line2": {
    "text": "فِكرَةٌ رائِعَة، كَم يَومًا سَتَبقى هُناكَ؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line2.mp3"
  },
  "conv8_3_line3": {
    "text": "أُخَطِّطُ لِلبَقاءِ عَشَرَةَ أَيّامٍ لِزِيارَةِ إِسطَنبولَ وَأَنطاليا",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line3.mp3"
  },
  "conv8_3_line4": {
    "text": "هَل حَجَزتَ الفُندُقَ وَالطَّيَرانَ بِالفِعل؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line4.mp3"
  },
  "conv8_3_line5": {
    "text": "لا بَعدُ، أَبحَثُ عَن أَفضَلِ العُروضِ الآن",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line5.mp3"
  },
  "conv8_3_line6": {
    "text": "أَنصَحُكَ بِالحَجزِ مُبَكِّرًا لِأَنَّ الأَسعارَ تَرتَفِع",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line6.mp3"
  },
  "conv8_3_line7": {
    "text": "نَصيحَةٌ جَيِّدَة، ما هِيَ الميزانيَّةُ المُناسِبَةُ بِرَأيِكَ؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line7.mp3"
  },
  "conv8_3_line8": {
    "text": "أَعتَقِدُ أَنَّ أَلفَي دولارٍ كافِيَةٌ لِرِحلَةٍ مُريحَة",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line8.mp3"
  },
  "conv8_3_line9": {
    "text": "وَماذا عَنِ الأَماكِنِ الَّتي يَجِبُ زِيارَتُها؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line9.mp3"
  },
  "conv8_3_line10": {
    "text": "لا تَفوتْ آيا صوفيا وَالبازارَ الكَبيرَ وَالبوسفور",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line10.mp3"
  },
  "conv8_3_line11": {
    "text": "شُكرًا عَلى النَّصائِح، هَل سَبَقَ أَن زُرتِ تُركِيا؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line11.mp3"
  },
  "conv8_3_line12": {
    "text": "نَعَم، زُرتُها العامَ الماضي وَكانَت تَجرِبَةً لا تُنسى",
    "path": "/audio/dialects/egyptian/conversations/conv8_3_line12.mp3"
  },
  "conv8_4_line1": {
    "text": "أَهلًا بِكَ، ما الَّذي يُزعِجُكَ اليَوم؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line1.mp3"
  },
  "conv8_4_line2": {
    "text": "دُكتور، أَشعُرُ بِأَلَمٍ شَديدٍ في المَعِدَةِ مُنذُ ثَلاثَةِ أَيّام",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line2.mp3"
  },
  "conv8_4_line3": {
    "text": "هَلِ الأَلَمُ مُستَمِرٌّ أَم يَأتي وَيَذهَب؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line3.mp3"
  },
  "conv8_4_line4": {
    "text": "يَأتي وَيَذهَب، وَيَزدادُ بَعدَ الأَكل",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line4.mp3"
  },
  "conv8_4_line5": {
    "text": "هَل لَدَيكَ أَعراضٌ أُخرى مِثلَ الغَثَيانِ أَوِ الحُمّى؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line5.mp3"
  },
  "conv8_4_line6": {
    "text": "نَعَم، أَشعُرُ بِالغَثَيانِ أَحيانًا وَلَيسَ لَدَيَّ شَهِيَّة",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line6.mp3"
  },
  "conv8_4_line7": {
    "text": "يَبدو أَنَّها التِهابٌ في المَعِدَة، هَل أَكَلتَ شَيئًا غَيرَ عادِيّ؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line7.mp3"
  },
  "conv8_4_line8": {
    "text": "رُبَّما، أَكَلتُ طَعامًا حارًّا جِدًّا قَبلَ أَربَعَةِ أَيّام",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line8.mp3"
  },
  "conv8_4_line9": {
    "text": "هَذا يُفَسِّرُ الأَمرَ، سَأَصِفُ لَكَ دَواءً وَنِظامًا غِذائِيًّا",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line9.mp3"
  },
  "conv8_4_line10": {
    "text": "شُكرًا دُكتور، مَتى سَأَشعُرُ بِالتَّحَسُّن؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line10.mp3"
  },
  "conv8_4_line11": {
    "text": "خِلالَ يَومَينِ إِن شاءَ الله، وَتَجَنَّبِ الطَّعامَ الحارّ",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line11.mp3"
  },
  "conv8_4_line12": {
    "text": "حاضِرٌ، جَزاكَ اللهُ خَيرًا",
    "path": "/audio/dialects/egyptian/conversations/conv8_4_line12.mp3"
  },
  "conv8_5_line1": {
    "text": "ما الَّذي تَدرُسُهُ في الجامِعَةِ يا يوسُف؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line1.mp3"
  },
  "conv8_5_line2": {
    "text": "أَدرُسُ الهَندَسَةَ المَعماريَّةَ، وَأَنا في السَّنَةِ الثّالِثَة",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line2.mp3"
  },
  "conv8_5_line3": {
    "text": "رائِعٌ، هَل تَستَمتِعُ بِدِراسَتِكَ؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line3.mp3"
  },
  "conv8_5_line4": {
    "text": "نَعَم كَثيرًا، خاصَّةً مَوادَّ التَّصميمِ وَالرَّسمِ الهَندَسِيّ",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line4.mp3"
  },
  "conv8_5_line5": {
    "text": "وَما هُوَ حُلمُكَ بَعدَ التَّخَرُّج؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line5.mp3"
  },
  "conv8_5_line6": {
    "text": "أَحلُمُ بِتَصميمِ مَبانٍ صَديقَةٍ لِلبيئَةِ في العالَمِ العَرَبِيّ",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line6.mp3"
  },
  "conv8_5_line7": {
    "text": "هَدَفٌ نَبيلٌ، أَنا أَدرُسُ الطِّبَّ وَأُريدُ أَن أُصبِحَ جَرّاحَة",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line7.mp3"
  },
  "conv8_5_line8": {
    "text": "ما شاءَ الله، الطِّبُّ تَخَصُّصٌ صَعبٌ وَلَكِنَّهُ مُهِمّ",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line8.mp3"
  },
  "conv8_5_line9": {
    "text": "نَعَم، أَدرُسُ كَثيرًا وَأَحيانًا أَسهَرُ اللَّيلَ كُلَّه",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line9.mp3"
  },
  "conv8_5_line10": {
    "text": "اللهُ يُعينُكِ، المُستَقبَلُ سَيَكونُ مُشرِقًا بِإِذنِ الله",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line10.mp3"
  },
  "conv8_5_line11": {
    "text": "آمين، هَل تُفَكِّرُ في إِكمالِ الدِّراساتِ العُليا؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line11.mp3"
  },
  "conv8_5_line12": {
    "text": "رُبَّما، أُفَكِّرُ في الحُصولِ عَلى الماجِستيرِ في الخارِج",
    "path": "/audio/dialects/egyptian/conversations/conv8_5_line12.mp3"
  },
  "conv8_6_line1": {
    "text": "كَم مَضى مِنَ الوَقتِ مُنذُ آخِرِ لِقاءٍ عائِلِيّ؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line1.mp3"
  },
  "conv8_6_line2": {
    "text": "تَقريبًا سَنَةٌ كامِلَة، مُنذُ عيدِ الفِطرِ الماضي",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line2.mp3"
  },
  "conv8_6_line3": {
    "text": "اشتَقتُ لِلجَميعِ كَثيرًا، خاصَّةً جَدَّتي وَأَعمامي",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line3.mp3"
  },
  "conv8_6_line4": {
    "text": "أَنا أَيضًا، جَدَّتُنا دائِمًا تَسأَلُ عَنكِ وَعَن دِراسَتِكِ",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line4.mp3"
  },
  "conv8_6_line5": {
    "text": "اللهُ يَحفَظُها، ما رَأيُكَ أَن نُنَظِّمَ لِقاءً قَريبًا؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line5.mp3"
  },
  "conv8_6_line6": {
    "text": "فِكرَةٌ مُمتازَة، رُبَّما في نِهايَةِ هَذا الشَّهر",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line6.mp3"
  },
  "conv8_6_line7": {
    "text": "أَينَ يُمكِنُ أَن نَجتَمِعَ؟ بَيتُ جَدَّتي أَم مَكانٌ آخَر؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line7.mp3"
  },
  "conv8_6_line8": {
    "text": "بَيتُ جَدَّتِنا أَفضَل، هُوَ كَبيرٌ وَمُريحٌ لِلجَميع",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line8.mp3"
  },
  "conv8_6_line9": {
    "text": "حَسَنًا، سَأَتَّصِلُ بِالعائِلَةِ وَأُخبِرُهُم بِالمَوعِد",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line9.mp3"
  },
  "conv8_6_line10": {
    "text": "وَأَنا سَأُساعِدُ في تَحضيرِ الطَّعامِ وَالتَّرتيبات",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line10.mp3"
  },
  "conv8_6_line11": {
    "text": "رائِعٌ، سَتَكونُ أَمسِيَةً جَميلَةً بِإِذنِ الله",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line11.mp3"
  },
  "conv8_6_line12": {
    "text": "إِن شاءَ الله، العائِلَةُ هِيَ أَغلى ما نَملِك",
    "path": "/audio/dialects/egyptian/conversations/conv8_6_line12.mp3"
  },
  "conv8_7_line1": {
    "text": "هَل قَرَأتَ الخَبَرَ عَنِ التَّطَوُّراتِ التِّقنِيَّةِ الجَديدَة؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line1.mp3"
  },
  "conv8_7_line2": {
    "text": "نَعَم، التَّكنولوجِيا تَتَقَدَّمُ بِسُرعَةٍ مُذهِلَةٍ هَذِهِ الأَيّام",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line2.mp3"
  },
  "conv8_7_line3": {
    "text": "صَحيحٌ، لَكِن أَشعُرُ أَنَّ النّاسَ أَصبَحوا مُدمِنينَ عَلى هَواتِفِهِم",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line3.mp3"
  },
  "conv8_7_line4": {
    "text": "أُوافِقُكَ تَمامًا، وَسائِلُ التَّواصُلِ الاجتِماعِيِّ لَها إِيجابِيّاتٌ وَسَلبِيّات",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line4.mp3"
  },
  "conv8_7_line5": {
    "text": "ما رَأيُكَ في تَأثيرِها عَلى الشَّبابِ وَالأَطفال؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line5.mp3"
  },
  "conv8_7_line6": {
    "text": "أَعتَقِدُ أَنَّها سِلاحٌ ذو حَدَّين، يَجِبُ استِخدامُها بِحِكمَة",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line6.mp3"
  },
  "conv8_7_line7": {
    "text": "كَلامٌ سَليمٌ، المُشكِلَةُ أَنَّ الكَثيرينَ يُضَيِّعونَ وَقتَهُم فيها",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line7.mp3"
  },
  "conv8_7_line8": {
    "text": "نَعَم، وَيَنسَونَ أَهَمِّيَّةَ التَّواصُلِ الحَقيقِيِّ وَجهًا لِوَجه",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line8.mp3"
  },
  "conv8_7_line9": {
    "text": "بِالضَّبط، يَجِبُ أَن نَجِدَ تَوازُنًا بَينَ العالَمَين",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line9.mp3"
  },
  "conv8_7_line10": {
    "text": "وَأَيضًا يَجِبُ تَعليمُ الأَجيالِ الجَديدَةِ الاستِخدامَ الصَّحيح",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line10.mp3"
  },
  "conv8_7_line11": {
    "text": "أَتَّفِقُ مَعَكَ، التَّربِيَةُ الرَّقمِيَّةُ أَصبَحَت ضَروريَّة",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line11.mp3"
  },
  "conv8_7_line12": {
    "text": "تَمامًا، هَذا هُوَ تَحَدّي عَصرِنا الحالِيّ",
    "path": "/audio/dialects/egyptian/conversations/conv8_7_line12.mp3"
  },
  "conv8_8_line1": {
    "text": "ما هُوَ مَفهومُكَ لِلسَّعادَةِ الحَقيقِيَّة؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line1.mp3"
  },
  "conv8_8_line2": {
    "text": "سُؤالٌ عَميقٌ، أَعتَقِدُ أَنَّ السَّعادَةَ تَكمُنُ في الرِّضا وَالقَناعَة",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line2.mp3"
  },
  "conv8_8_line3": {
    "text": "أُوافِقُكِ، لَكِن أَلَيسَ الطُّموحُ مُهِمًّا أَيضًا؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line3.mp3"
  },
  "conv8_8_line4": {
    "text": "بَلى، المُهِمُّ هُوَ التَّوازُنُ بَينَ الطُّموحِ وَالرِّضا",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line4.mp3"
  },
  "conv8_8_line5": {
    "text": "وَما رَأيُكِ في مَعنى النَّجاحِ في الحَياة؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line5.mp3"
  },
  "conv8_8_line6": {
    "text": "النَّجاحُ لَيسَ فَقَط في المالِ وَالشُّهرَة، بَل في التَّأثيرِ الإِيجابِيّ",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line6.mp3"
  },
  "conv8_8_line7": {
    "text": "كَلامٌ جَميلٌ، إِذًا النَّجاحُ يَرتَبِطُ بِخِدمَةِ الآخَرين؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line7.mp3"
  },
  "conv8_8_line8": {
    "text": "نَعَم بِالتَّأكيد، وَأَيضًا في تَحقيقِ السَّلامِ الدّاخِلِيّ",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line8.mp3"
  },
  "conv8_8_line9": {
    "text": "هَل تَعتَقِدينَ أَنَّ المالَ يَجلِبُ السَّعادَة؟",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line9.mp3"
  },
  "conv8_8_line10": {
    "text": "المالُ وَسيلَةٌ وَلَيسَ غايَةً، يُساعِدُ لَكِنَّهُ لا يَضمَنُ السَّعادَة",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line10.mp3"
  },
  "conv8_8_line11": {
    "text": "حِكمَةٌ بالِغَة، الصِّحَّةُ وَالعائِلَةُ أَهَمُّ مِنَ المال",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line11.mp3"
  },
  "conv8_8_line12": {
    "text": "تَمامًا، هَذِهِ هِيَ الكُنوزُ الحَقيقِيَّةُ في الحَياة",
    "path": "/audio/dialects/egyptian/conversations/conv8_8_line12.mp3"
  },
  "quran_1_1": {
    "text": "بِسمِ اللَّهِ الرَّحمَٰنِ الرَّحيم",
    "path": "/audio/dialects/egyptian/quran/quran_1_1.mp3"
  },
  "quran_1_2": {
    "text": "الحَمدُ لِلَّهِ رَبِّ العالَمين",
    "path": "/audio/dialects/egyptian/quran/quran_1_2.mp3"
  },
  "quran_112_1": {
    "text": "قُل هُوَ اللَّهُ أَحَد",
    "path": "/audio/dialects/egyptian/quran/quran_112_1.mp3"
  },
  "quran_112_2": {
    "text": "اللَّهُ الصَّمَد",
    "path": "/audio/dialects/egyptian/quran/quran_112_2.mp3"
  },
  "quran_112_3": {
    "text": "لَم يَلِد وَلَم يولَد",
    "path": "/audio/dialects/egyptian/quran/quran_112_3.mp3"
  },
  "quran_112_4": {
    "text": "وَلَم يَكُن لَّهُ كُفُوًا أَحَد",
    "path": "/audio/dialects/egyptian/quran/quran_112_4.mp3"
  },
  "quran_113_1": {
    "text": "قُل أَعوذُ بِرَبِّ الفَلَق",
    "path": "/audio/dialects/egyptian/quran/quran_113_1.mp3"
  },
  "quran_113_2": {
