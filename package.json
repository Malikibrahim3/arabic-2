{
  "name": "arabic-app-2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:comprehensive": "playwright test e2e-comprehensive.spec.ts",
    "test:ui": "playwright test e2e-comprehensive.spec.ts --ui",
    "test:headed": "playwright test e2e-comprehensive.spec.ts --headed",
    "test:debug": "playwright test e2e-comprehensive.spec.ts --debug",
    "test:report": "playwright show-report",
    "audio:test": "tsx scripts/test_azure_connection.ts",
    "audio:generate": "tsx scripts/generate_audio_azure.ts",
    "audio:vocabulary": "tsx scripts/generate_vocabulary_audio_azure.ts",
    "audio:extract": "tsx scripts/extract_vocabulary.ts",
    "audio:rebuild-json": "tsx scripts/rebuild_vocabulary_json.ts",
    "audio:upload": "tsx scripts/upload_to_supabase.ts",
    "audio:clear": "tsx scripts/clear_supabase_audio.ts",
    "migrate:azure": "bash scripts/migrate-to-azure.sh",
    "tts-qa": "cd scripts/azure/arabic-tts-qa && bash run_pipeline.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "lucide-react": "^0.575.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}